# Optional: configure these to receive emails from the contact form
# If you do NOT set them, the backend will just log messages to the terminal.

PORT=3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

TO_EMAIL=your_email@gmail.com
FROM_EMAIL=your_email@gmail.com
